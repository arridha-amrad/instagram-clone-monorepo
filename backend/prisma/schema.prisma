// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("todos")
}

model Users {
  id              String   @id
  name            String
  email           String
  emailVerified   Boolean  @default(false)
  image           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  username        String
  displayUsername String?

  // Relasi
  sessions         Sessions[]
  accounts         Accounts[]
  collaborators    Collaborator[]
  commentLikes     CommentLike[]
  concretePosts    ConcretePost[]
  postComments     PostComment[]
  postLikes        PostLike[]
  postTaggedUsers  PostTaggedUser[]
  reposts          Repost[]
  bookmarks        Bookmark[]
  searchHistories  SearchHistory[]  @relation("UserSearches")
  searchedByOthers SearchHistory[]  @relation("TargetSearches")

  @@unique([email])
  @@unique([username])
  @@map("users")
}

model Sessions {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  users     Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Accounts {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relasi
  users Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verifications {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model Collaborator {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relasi
  post ConcretePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user Users        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], map: "collaborators_post_id_user_id_unique")
  @@map("collaborators")
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relasi
  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    Users       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId], map: "comment_likes_user_id_comment_id_unique")
  @@map("comment_likes")
}

model Media {
  id        String    @id @default(cuid())
  postId    String    @map("post_id")
  url       String
  mediaType MediaType @map("media_type")
  order     Int       @map("order")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relasi
  post        ConcretePost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  taggedUsers PostTaggedUser[]

  @@map("media")
}

model ConcretePost {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  caption     String
  location    String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")
  aspectRatio AspectRatio @map("aspect_ratio")

  // Relasi
  user          Users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  collaborators Collaborator[]
  media         Media[]
  comments      PostComment[]
  postLikes     PostLike[]
  reposts       Repost[]
  bookmarks     Bookmark[]

  @@map("post")
}

model PostComment {
  id        String   @id @default(cuid())
  content   String
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relasi
  post          ConcretePost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          Users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment PostComment?  @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  childComments PostComment[] @relation("ParentChildren")
  commentLikes  CommentLike[]

  @@map("post_comments")
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relasi
  post ConcretePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user Users        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], map: "post_likes_user_id_post_id_unique")
  @@map("post_likes")
}

model PostTaggedUser {
  id          String   @id @default(cuid())
  mediaId     String   @map("media_id")
  userId      String   @map("user_id")
  coordinateX Float    @map("coordinate_x")
  coordinateY Float    @map("coordinate_y")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relasi
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tagged_users")
}

model Repost {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user Users        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post ConcretePost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], map: "repost_user_id_post_id_unique")
  @@map("repost")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user Users        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post ConcretePost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], map: "bookmark_user_id_post_id_unique")
  @@map("bookmarks")
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  targetId  String   @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relasi
  user       Users @relation("UserSearches", fields: [userId], references: [id], onDelete: Cascade)
  targetUser Users @relation("TargetSearches", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId], map: "search_history_user_id_target_id_unique")
  @@index([userId])
  @@map("search_histories")
}

// ==========================================
// ENUMS
// ==========================================

enum AspectRatio {
  RATIO_1_1  @map("1 / 1")
  RATIO_4_5  @map("4 / 5")
  RATIO_9_16 @map("9 / 16")

  @@map("aspect_ratio")
}

enum GenderOptionsEnum {
  NONE   @map("-")
  FEMALE @map("female")
  MALE   @map("male")

  @@map("gender_options_enum")
}

enum MediaType {
  IMAGE @map("image")
  VIDEO @map("video")

  @@map("media_type")
}
